# ============================================================
# YT Automation Pipeline — Required Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# --- YouTube API ---
# Comma-separated list of YouTube Data API v3 keys
# Get from: Google Cloud Console → APIs & Services → Credentials
YOUTUBE_API_KEYS=AIza...,AIza...,AIza...

# --- Gmail API (OAuth2) ---
# Base64-encoded JSON of OAuth2 credentials and token
# Generate via: python scripts/gmail_auth.py
GMAIL_CREDENTIALS_JSON=base64-encoded-credentials-json
GMAIL_TOKEN_JSON=base64-encoded-token-json
GMAIL_SENDER_EMAIL=you@gmail.com
GMAIL_APPROVAL_TO=you@gmail.com

# --- Google Cloud ---
GCS_BUCKET_NAME=your-gcs-bucket
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- AI Agents ---
ANTHROPIC_API_KEY=sk-ant-...your-claude-api-key
GEMINI_API_KEY=AIza...your-gemini-api-key

# --- Optional Tuning ---
LOG_LEVEL=INFO
VIRAL_MIN_VIEWS_48H=7000
VIRAL_MIN_VIEWS_12H=4000
MAX_VIDEO_AGE_HOURS=48
# PORT=8000  # Railway sets this automatically

# --- API Security ---
# Set this to require X-API-Key header on all mutation endpoints.
# Leave unset for development mode (no auth required).
API_SECRET=your-random-api-secret-here

# --- Cloud Functions (Phase 3+4) ---
GCP_PROJECT_ID=your-gcp-project-id
AUDIO_EXTRACT_FUNCTION_URL=https://us-central1-your-project.cloudfunctions.net/upload-audio-to-gcs
IMAGE_BATCH_FUNCTION_URL=https://us-central1-your-project.cloudfunctions.net/image-batch-requests
VIDEO_RENDER_FUNCTION_URL=https://us-central1-your-project.cloudfunctions.net/generate-video
VIDEO_UPLOAD_FUNCTION_URL=https://us-central1-your-project.cloudfunctions.net/upload-video
